oversampler = RandomOverSampler(random_state=42)
X_over, y_over = oversampler.fit_resample(X_train_vec, y_train_split)

print(f"Original size: {X_train_vec.shape[0]:,}")
print(f"After oversampling: {X_over.shape[0]:,}")

model_over = LogisticRegression(max_iter=10000, random_state=42)
model_over.fit(X_over, y_over)
y_pred_over = model_over.predict(X_val_vec)

accuracy_over = accuracy_score(y_val_split, y_pred_over)
precision_over = precision_score(y_val_split, y_pred_over, average='macro')
recall_over = recall_score(y_val_split, y_pred_over, average='macro')
f1_over = f1_score(y_val_split, y_pred_over, average='macro')

print(f"Accuracy: {accuracy_over:.4f} ({accuracy_over - accuracy_baseline:+.4f})")
print(f"Macro Precision: {precision_over:.4f} ({precision_over - precision_baseline:+.4f})")
print(f"Macro Recall: {recall_over:.4f} ({recall_over - recall_baseline:+.4f})")
print(f"Macro F1: {f1_over:.4f} ({f1_over - f1_baseline:+.4f})")

# ============================================================================
# 7. PIPELINE 4: SMOTE
# ============================================================================

print("\n" + "="*80)
print("PIPELINE 4: SMOTE")
print("="*80)

# SMOTE needs dense array - use limited features
X_train_dense = X_train_vec.toarray()[:, :1000]
X_val_dense = X_val_vec.toarray()[:, :1000]

smote = SMOTE(random_state=42, k_neighbors=3)
X_smote, y_smote = smote.fit_resample(X_train_dense, y_train_split)

print(f"Original size: {X_train_dense.shape[0]:,}")
print(f"After SMOTE: {X_smote.shape[0]:,}")

model_smote = LogisticRegression(max_iter=10000, random_state=42)
model_smote.fit(X_smote, y_smote)
y_pred_smote = model_smote.predict(X_val_dense)

accuracy_smote = accuracy_score(y_val_split, y_pred_smote)
precision_smote = precision_score(y_val_split, y_pred_smote, average='macro')
recall_smote = recall_score(y_val_split, y_pred_smote, average='macro')
f1_smote = f1_score(y_val_split, y_pred_smote, average='macro')

print(f"Accuracy: {accuracy_smote:.4f} ({accuracy_smote - accuracy_baseline:+.4f})")
print(f"Macro Precision: {precision_smote:.4f} ({precision_smote - precision_baseline:+.4f})")
print(f"Macro Recall: {recall_smote:.4f} ({recall_smote - recall_baseline:+.4f})")
print(f"Macro F1: {f1_smote:.4f} ({f1_smote - f1_baseline:+.4f})")

# ============================================================================
# 8. SUMMARY COMPARISON
# ============================================================================

print("\n" + "="*80)
print("SUMMARY: ALL PIPELINES")
print("="*80)

results = pd.DataFrame({
    'Method': ['No Balancing', 'Undersampling', 'Oversampling', 'SMOTE'],
    'Accuracy': [accuracy_baseline, accuracy_under, accuracy_over, accuracy_smote],
    'Precision': [precision_baseline, precision_under, precision_over, precision_smote],
    'Recall': [recall_baseline, recall_under, recall_over, recall_smote],
    'F1-Score': [f1_baseline, f1_under, f1_over, f1_smote]
})

print("\n" + results.to_string(index=False))

# ============================================================================
# 9. CROSSTAB CONFUSION MATRICES (with Precision and F1)
# ============================================================================

print("\n" + "="*80)
print("CROSSTAB CONFUSION MATRICES (Accuracy, Precision, Recall & F1)")
print("="*80)

def create_confusion_metrics(y_true, y_pred, method_name):
    """Create crosstab with accuracy, precision, recall and F1 per class"""
    
    ct = pd.crosstab(y_true, y_pred, rownames=['True'], colnames=['Predicted'])
    
    metrics = []
    for cls in sorted(np.unique(y_true)):
        tp = ct.loc[cls, cls] if cls in ct.index and cls in ct.columns else 0
        total_actual = ct.loc[cls].sum() if cls in ct.index else 0
        total_pred = ct[cls].sum() if cls in ct.columns else 0
        
        recall = tp / total_actual if total_actual > 0 else 0
        precision = tp / total_pred if total_pred > 0 else 0
        f1 = 2 * (precision * recall) / (precision + recall) if (precision + recall) > 0 else 0
        accuracy = tp / total_actual if total_actual > 0 else 0
        
        metrics.append({
            'Class': cls,
            'Samples': total_actual,
            'Accuracy': accuracy,
            'Precision': precision,
            'Recall': recall,
            'F1-Score': f1
        })
    
    metrics_df = pd.DataFrame(metrics)
    
    print(f"\n{method_name}")
    print("-" * 80)
    print(metrics_df.to_string(index=False))
    
    avg_accuracy = metrics_df['Accuracy'].mean()
    avg_precision = metrics_df['Precision'].mean()
    avg_recall = metrics_df['Recall'].mean()
    avg_f1 = metrics_df['F1-Score'].mean()
    
    print(f"\nAverage Accuracy: {avg_accuracy:.4f}")
    print(f"Average Precision: {avg_precision:.4f}")
    print(f"Average Recall: {avg_recall:.4f}")
    print(f"Average F1-Score: {avg_f1:.4f}")
    
    return metrics_df

# Create crosstabs for all methods
metrics_baseline = create_confusion_metrics(y_val_split, y_pred_baseline, 
                                           "BASELINE (No Balancing)")

metrics_under = create_confusion_metrics(y_val_split, y_pred_under, 
                                        "UNDERSAMPLING")

metrics_over = create_confusion_metrics(y_val_split, y_pred_over, 
                                       "OVERSAMPLING")

metrics_smote = create_confusion_metrics(y_val_split, y_pred_smote, 
                                        "SMOTE")

# ============================================================================
# 10. COMPLETE RESULTS TABLE OVERVIEW
# ============================================================================

print("\n" + "="*80)
