import pandas as pd
import numpy as np
from sklearn.feature_extraction.text import TfidfVectorizer
from sklearn.model_selection import train_test_split
from sklearn.linear_model import LogisticRegression
from sklearn.metrics import accuracy_score, recall_score, f1_score, precision_score
from imblearn.over_sampling import RandomOverSampler, SMOTE
from imblearn.under_sampling import RandomUnderSampler

# ============================================================================
# CONFIGURATION
# ============================================================================

BASE_PATH = "YOUR_PATH"
X_TRAIN_PATH = BASE_PATH + "X_train.csv"
Y_TRAIN_PATH = BASE_PATH + "y_train.csv"

# ============================================================================
# 1. LOAD DATA & SHOW CURRENT CLASS IMBALANCE
# ============================================================================

print("="*80)
print("1. CURRENT CLASS IMBALANCE")
print("="*80)

X_train = pd.read_csv(X_TRAIN_PATH)
y_train = pd.read_csv(Y_TRAIN_PATH)

# Create text
X_train['text'] = (X_train['designation'].fillna('') + ' ' + 
                   X_train['description'].fillna('')).str.strip()

y = y_train['prdtypecode'].values

# Show class distribution
class_counts = pd.Series(y).value_counts().sort_index()
print("\nClass Distribution:")
print(class_counts)

print(f"\nImbalance Ratio: {class_counts.max() / class_counts.min():.1f}:1")
print(f"Largest class: {class_counts.max()} samples")
print(f"Smallest class: {class_counts.min()} samples")

# ============================================================================
# 2. SPLIT DATA FIRST (NO DATA LEAKAGE)
# ============================================================================

print("\n" + "="*80)
print("2. SPLITTING DATA (BEFORE VECTORIZATION)")
print("="*80)

# Split TEXT first, then vectorize (prevents data leakage)
X_train_text, X_val_text, y_train_split, y_val_split = train_test_split(
    X_train['text'],
    y,
    test_size=0.2,
    random_state=42,
    stratify=y
)

print(f"Training samples: {len(X_train_text):,}")
print(f"Validation samples: {len(X_val_text):,}")

# ============================================================================
# 3. VECTORIZE AFTER SPLIT (NO DATA LEAKAGE)
# ============================================================================

print("\n" + "="*80)
print("3. VECTORIZING TEXT (NO DATA LEAKAGE)")
print("="*80)

vectorizer = TfidfVectorizer(max_features=5000)

# Fit on training text only
X_train_vec = vectorizer.fit_transform(X_train_text)

# Transform validation text (using training vocabulary)
X_val_vec = vectorizer.transform(X_val_text)

print(f"Vocabulary size: {len(vectorizer.vocabulary_):,}")
print(f"Training matrix: {X_train_vec.shape}")
print(f"Validation matrix: {X_val_vec.shape}")

# ============================================================================
# 4. PIPELINE 1: NO BALANCING (BASELINE)
# ============================================================================

print("\n" + "="*80)
print("PIPELINE 1: NO BALANCING (BASELINE)")
print("="*80)

model_baseline = LogisticRegression(max_iter=10000, random_state=42)
model_baseline.fit(X_train_vec, y_train_split)
y_pred_baseline = model_baseline.predict(X_val_vec)

accuracy_baseline = accuracy_score(y_val_split, y_pred_baseline)
precision_baseline = precision_score(y_val_split, y_pred_baseline, average='macro')
recall_baseline = recall_score(y_val_split, y_pred_baseline, average='macro')
f1_baseline = f1_score(y_val_split, y_pred_baseline, average='macro')

print(f"Accuracy: {accuracy_baseline:.4f}")
print(f"Macro Precision: {precision_baseline:.4f}")
print(f"Macro Recall: {recall_baseline:.4f}")
print(f"Macro F1: {f1_baseline:.4f}")

# ============================================================================
# 5. PIPELINE 2: RANDOM UNDERSAMPLING
# ============================================================================

print("\n" + "="*80)
print("PIPELINE 2: RANDOM UNDERSAMPLING")
print("="*80)

undersampler = RandomUnderSampler(random_state=42)
X_under, y_under = undersampler.fit_resample(X_train_vec, y_train_split)

print(f"Original size: {X_train_vec.shape[0]:,}")
print(f"After undersampling: {X_under.shape[0]:,}")

model_under = LogisticRegression(max_iter=10000, random_state=42)
model_under.fit(X_under, y_under)
y_pred_under = model_under.predict(X_val_vec)

accuracy_under = accuracy_score(y_val_split, y_pred_under)
precision_under = precision_score(y_val_split, y_pred_under, average='macro')
recall_under = recall_score(y_val_split, y_pred_under, average='macro')
f1_under = f1_score(y_val_split, y_pred_under, average='macro')

print(f"Accuracy: {accuracy_under:.4f} ({accuracy_under - accuracy_baseline:+.4f})")
print(f"Macro Precision: {precision_under:.4f} ({precision_under - precision_baseline:+.4f})")
print(f"Macro Recall: {recall_under:.4f} ({recall_under - recall_baseline:+.4f})")
print(f"Macro F1: {f1_under:.4f} ({f1_under - f1_baseline:+.4f})")

# ============================================================================
# 6. PIPELINE 3: RANDOM OVERSAMPLING
# ============================================================================

print("\n" + "="*80)
print("PIPELINE 3: RANDOM OVERSAMPLING")
